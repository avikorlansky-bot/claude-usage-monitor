#!/bin/bash
# Launcher inside Claude Usage Monitor.app. Sets up a venv on first run
# (in ~/Library/Application Support/...) and launches app.py.

set -e

RESOURCES="$(cd "$(dirname "${BASH_SOURCE[0]}")/../Resources" && pwd)"
SUPPORT="$HOME/Library/Application Support/Claude Usage Monitor"
mkdir -p "$SUPPORT"
VENV="$SUPPORT/.venv"
STAMP="$VENV/.requirements.stamp"
REQS="$RESOURCES/requirements.txt"

# Find a Python 3 interpreter.
PY=""
for c in python3 /opt/homebrew/bin/python3 /usr/local/bin/python3 /usr/bin/python3; do
  if command -v "$c" >/dev/null 2>&1; then
    PY="$(command -v "$c")"
    break
  fi
done
if [ -z "$PY" ]; then
  osascript -e 'display dialog "Python 3 is not installed.\n\nInstall it from https://www.python.org/downloads/ (or run: xcode-select --install in Terminal) and try again." buttons {"OK"} default button 1 with icon stop with title "Claude Usage Monitor"'
  exit 1
fi

# Create or refresh the venv.
if [ ! -d "$VENV" ]; then
  "$PY" -m venv "$VENV"
  "$VENV/bin/pip" install --upgrade pip >/dev/null 2>&1 || true
fi
if [ ! -f "$STAMP" ] || [ "$REQS" -nt "$STAMP" ]; then
  "$VENV/bin/pip" install -r "$REQS" >/dev/null 2>&1
  touch "$STAMP"
fi

cd "$RESOURCES"
exec "$VENV/bin/python" app.py
